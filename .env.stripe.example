# Direct Stripe billing (replaces Clerk Billing - Clerk does not support
# Singapore-based Stripe accounts). Add these to .env.local locally AND to
# Vercel project env (Production + Preview).
#
# 1) Secret key: https://dashboard.stripe.com/apikeys  (use sk_live_... in prod)
STRIPE_SECRET_KEY=
#
# Webhook signing secret(s): one whsec_ from your FinTRK webhook destination.
# If you created multiple Stripe destinations (one per event), paste ALL secrets
# comma-separated on one line - FinTRK tries each until one verifies.
STRIPE_WEBHOOK_SECRET=
#
# 3) Canonical origin used for checkout success/cancel + portal return URLs.
NEXT_PUBLIC_APP_URL=https://fintrk.io
#
# Optional: set to "false" locally to disable the paywall while developing.
# FINTRK_BILLING_ENFORCED=false
