# Preferred: add these to .env.local (gitignored) next to package.json — same as Next.js + vercel env pull.
# Alternative: copy this file to .env.clerk.fin-trk (gitignored).
# Keys: https://dashboard.clerk.com → Applications → FinTRK → Configure → API keys
# Then: bash scripts/sync-clerk-env-to-vercel.sh
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhooks → https://dashboard.clerk.com → Webhooks → Signing Secret (FinTRK URL: /api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET=
